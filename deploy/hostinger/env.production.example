# Copie para /var/www/arpgov/.env no VPS e preencha os valores.
# cp deploy/hostinger/env.production.example /var/www/arpgov/.env

FLASK_SECRET_KEY=GERE_UMA_CHAVE_LONGA_ALEATORIA_AQUI
FLASK_PRODUCTION=1
FLASK_DEBUG=0

TRUST_PROXY=1
SESSION_COOKIE_SECURE=1

# Domínio público com HTTPS (sem barra no final)
PUBLIC_BASE_URL=https://ARPGOV_DOMAIN

PAINEL_ADMIN_PASSWORD=senha-forte-do-painel
CRM_ADMIN_PASSWORD=senha-forte-do-crm

# E-mail Hostinger (opcional — painel Hostinger → E-mails)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=noreply@seudominio.com.br
# SMTP_PASSWORD=senha-do-email
# SMTP_FROM=noreply@seudominio.com.br
# SMTP_USE_TLS=true

# Pexels (sugestão de imagem no cadastro de produto — gratuito)
# PEXELS_API_KEY=
