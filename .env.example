FLASK_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
# Desenvolvimento local: FLASK_DEBUG=1 ativa o depurador Werkzeug (nunca em produção).
# FLASK_DEBUG=0

# Atrás de Nginx/Caddy com HTTPS: TRUST_PROXY=1 para respeitar X-Forwarded-* e cookies seguros.
# TRUST_PROXY=1
# SESSION_COOKIE_SECURE=1
# SameSite opcional: Lax (padrão), Strict ou None (None exige SESSION_COOKIE_SECURE=1).

# Porta do site (padrão 5001)
# PORTAL_PORT=5001

# Painel do site (catálogo, preços, textos públicos). Pode usar PORTAL_ADMIN_PASSWORD se preferir o nome antigo.
PAINEL_ADMIN_PASSWORD=sua-senha-do-painel
# PORTAL_ADMIN_PASSWORD=alternativa-ao-PAINEL_ADMIN_PASSWORD

# CRM de oportunidades — senha diferente do painel
CRM_ADMIN_PASSWORD=sua-senha-do-crm

# Opcional: uma senha que vale no Painel, CRM, Área do cliente, Comercial, Parceiro e Intranet (/empresa).
# Deixe em branco para desativar. Áreas com login de e-mail+senha entram como o primeiro cadastro ativo da tabela.
# PORTAL_MASTER_PASSWORD=

# E-mail (avisos ao cliente sobre o lead e à equipe quando o cliente envia mensagem no chat)
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@seudominio.com
# SMTP_USE_TLS=true
# URL pública do site (links nos e-mails). Ex.: https://portal.exemplo.gov.br
# PUBLIC_BASE_URL=http://127.0.0.1:5001

# Deploy em dois servidores: site público só com cliente + parceiro; painel/CRM no interno.
# PORTAL_PUBLIC_ONLY=1
# STAFF_PORTAL_URL=https://painel.seudominio.com.br

# Sugestão de imagem no cadastro de produto (Painel). Pexels é gratuito; OpenAI (DALL·E) é opcional e pago.
# PEXELS_API_KEY=...
# OPENAI_API_KEY=sk-...   # opcional; deixe comentado ou vazio se não for usar

# Braspress — rastreamento (intranet Logística / empresa). Solicite usuário e senha à transportadora.
# BRASPRESS_API_BASE=https://api.braspress.com
# CNPJ do remetente usado na URL (ajuste no formulário se precisar de outro):
# BRASPRESS_CNPJ_REMETENTE=00000000000100
# BRASPRESS_API_USER=usuario_api
# BRASPRESS_API_PASSWORD=senha_api
